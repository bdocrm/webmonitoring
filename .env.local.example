# Local development environment
# Copy this file to .env.local and update with your actual credentials

# Database (Supabase)
# Get your connection string from: https://supabase.com/dashboard/project/[project-id]/settings/database
# Connection string format: postgresql://postgres.[PROJECT-ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-key-change-in-production-very-important"

# Google PageSpeed Insights API (optional)
GOOGLE_PAGESPEED_API_KEY=""

# Email Configuration (Gmail example)
EMAIL_FROM="noreply@websitemonitoring.local"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"

# Crawler Settings
CRAWLER_TIMEOUT="30000"
MAX_PAGES_PER_SCAN="100"
SCAN_INTERVAL_HOURS="24"

# Admin User (for seeding)
ADMIN_EMAIL="admin@websitemonitoring.com"
ADMIN_PASSWORD="admin123"

# Logging
LOG_LEVEL="debug"

# Feature Flags
ENABLE_EMAIL_ALERTS="false"
ENABLE_PDF_EXPORT="true"
ENABLE_COMPETITOR_TRACKING="true"
