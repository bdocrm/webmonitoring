# Local development environment
# Copy this file to .env.local and update with your actual credentials
# IMPORTANT: Never commit .env.local to version control!

# Database (Supabase)
# Get your connection string from: https://supabase.com/dashboard/project/[project-id]/settings/database
# Connection string format: postgresql://postgres.[PROJECT-ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# NextAuth Configuration (CRITICAL!)
# Generate a secret: openssl rand -base64 32
# In production, this MUST be a secure random string
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-dev-secret-key-here-change-in-production"

# OAuth Providers (Optional - enables social login)
# Google: https://console.cloud.google.com
#GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
#GOOGLE_CLIENT_SECRET="your-client-secret"

# GitHub: https://github.com/settings/developers
#GITHUB_ID="your-github-app-id"
#GITHUB_SECRET="your-github-app-secret"

# Google PageSpeed Insights API (optional)
GOOGLE_PAGESPEED_API_KEY=""

# Email Configuration (Gmail example)
EMAIL_FROM="noreply@websitemonitoring.local"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"

# Crawler Settings
CRAWLER_TIMEOUT="30000"
MAX_PAGES_PER_SCAN="100"
SCAN_INTERVAL_HOURS="24"

# Admin User (for seeding - set your own secure credentials)
ADMIN_EMAIL="your-admin@example.com"
ADMIN_PASSWORD="your-secure-password-here"

# PgAdmin Configuration (for Docker)
PGADMIN_DEFAULT_EMAIL="pgadmin@example.com"
PGADMIN_DEFAULT_PASSWORD="pgadmin-password"

# Logging & Debug
LOG_LEVEL="debug"
DEBUG="true"

# Feature Flags
ENABLE_EMAIL_ALERTS="false"
ENABLE_PDF_EXPORT="true"
ENABLE_COMPETITOR_TRACKING="true"

# API Rate Limiting
RATE_LIMIT_WINDOW_MS="15000"
RATE_LIMIT_MAX_REQUESTS="100"
