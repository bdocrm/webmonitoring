# Database (Use Supabase)
# Get your connection string from Supabase Dashboard > Settings > Database
DATABASE_URL="postgresql://postgres.[PROJECT-ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# NextAuth Configuration
# Generate a secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-generated-secret-key-here-very-important"
SHARE_DASHBOARD_BASE_URL="https://your-app.vercel.app"

# OAuth Providers (Optional - for enhanced authentication)
# Google OAuth Setup: https://console.cloud.google.com
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth Setup: https://github.com/settings/developers
GITHUB_ID="your-github-app-id"
GITHUB_SECRET="your-github-app-secret"

# Google PageSpeed Insights API
GOOGLE_PAGESPEED_API_KEY="your-api-key"

# Brand Listening (pipe-separated values)
LISTENING_BRAND_NAME="Allianz-Synergia"
LISTENING_SEARCH_TERMS="Allianz Synergia|Allianz-Synergia|Allianz-Synergia, Inc.|allianzsynergia.com.ph"
LISTENING_EXCLUDED_TERMS="Allianz PNB|Allianz Life"
# Optional: replace the default verified source watchlist; separate URLs with |
LISTENING_WATCH_URLS=""
# Optional: RSS feed URLs created in Google Alerts, separated with |
GOOGLE_ALERTS_RSS_URLS=""
# Optional: existing Custom Search customers only; Google closes this API on 2027-01-01
GOOGLE_CUSTOM_SEARCH_API_KEY=""
GOOGLE_CUSTOM_SEARCH_CX=""

# Email Configuration (for alerts)
EMAIL_FROM="noreply@websitemonitoring.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
ALERT_EMAIL_RECIPIENTS="alerts@example.com,owner@example.com"

# Admin User (set your own secure credentials)
# These are used during database seeding
ADMIN_EMAIL="your-admin@example.com"
ADMIN_PASSWORD="your-secure-password-here"

# PgAdmin Configuration (for Docker)
PGADMIN_DEFAULT_EMAIL="pgadmin@example.com"
PGADMIN_DEFAULT_PASSWORD="pgadmin-password"

# Crawler Settings
CRAWLER_TIMEOUT="30000"
MAX_PAGES_PER_SCAN="100"
SCAN_INTERVAL_HOURS="24"

# Logging & Debug
NODE_ENV="development"
LOG_LEVEL="debug"
DEBUG="true"
